# Environment Variables for TISB World
# Copy this file to .env and fill in your actual values

# YouTube Data API v3 Key
# Get from: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# Spotify API Credentials  
# Get from: https://developer.spotify.com/dashboard/applications
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Vite Environment Variables (for frontend)
VITE_YOUTUBE_API_KEY=your_youtube_api_key_here
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here
VITE_SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Google OAuth Client ID for Admin Authentication
# Get from: https://console.cloud.google.com/apis/credentials
# Make sure to add your domain to authorized JavaScript origins
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# Notion API Integration Token for Video Tracker
# Get from: https://www.notion.so/my-integrations
# Create integration → Copy "Internal Integration Token"
# Share your database with the integration
NOTION_API_KEY=your_notion_integration_token_here

# ─────────────────────────────────────────────────────────────
# Content Engine (/admin/content-engine)
# Each platform block below is optional — leave blank to disable.
# Set CRON_SECRET in production to lock down /api/content/cron.
# ─────────────────────────────────────────────────────────────

# Shared
CRON_SECRET=
# Override the queue file path (defaults to api/content/_data/queue.json)
CONTENT_QUEUE_FILE=

# Email (nodemailer SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=

# LinkedIn (personal profile UGC posts)
# Token: developer.linkedin.com → create app → request "Share on LinkedIn"
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_ID=
# Optional: if set, posts are POSTed to this URL instead of the LinkedIn API
LINKEDIN_WEBHOOK_URL=

# Facebook Page
# Page access token (long-lived) from developers.facebook.com/tools/explorer
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_WEBHOOK_URL=

# Instagram (Business / Creator account via Meta Graph API)
# Requires an image_url on every post; text-only IG posts are not allowed.
INSTAGRAM_BUSINESS_ID=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_WEBHOOK_URL=